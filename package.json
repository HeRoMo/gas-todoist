{
  "name": "gas-todoist",
  "version": "1.1.0",
  "description": "Todoist client for Google Apps Script",
  "main": "index.js",
  "author": "HeRoMo",
  "license": "MIT",
  "scripts": {
    "eslint": "eslint .",
    "build": "tsc && cp src/appsscript.json dist/",
    "clasp:push": "yarn build && ./node_modules/.bin/clasp push",
    "clasp:open": "./node_modules/.bin/clasp open"
  },
  "devDependencies": {
    "@google/clasp": "3.3.0",
    "typescript": "^6.0.0",
    "@types/google-apps-script": "2.0.8",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "@eslint/eslintrc": "^3.3.1",
    "eslint": "10.4.0",
    "globals": "^17.0.0",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-plugin-googleappsscript": "1.0.5",
    "eslint-plugin-import": "2.32.0"
  }
}
